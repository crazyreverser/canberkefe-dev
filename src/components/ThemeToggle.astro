---
// cycles hacker → dark → light → hacker. persists to localStorage.
---
<button id="theme-toggle" class="theme-btn" type="button" aria-label="cycle theme">
  <span class="dot" aria-hidden="true"></span>
  <span id="theme-label">HACKER</span>
</button>

<script is:inline>
  (function () {
    const KEY = 'cb_theme';
    const order = ['hacker', 'dark', 'light'];
    const root = document.documentElement;
    const label = document.getElementById('theme-label');
    function apply(t) {
      root.setAttribute('data-theme', t);
      if (label) label.textContent = t.toUpperCase();
    }
    let cur;
    try { cur = localStorage.getItem(KEY); } catch (e) {}
    if (!cur || !order.includes(cur)) cur = root.getAttribute('data-theme') || 'hacker';
    apply(cur);

    document.getElementById('theme-toggle').addEventListener('click', () => {
      const i = order.indexOf(root.getAttribute('data-theme'));
      const next = order[(i + 1) % order.length];
      apply(next);
      try { localStorage.setItem(KEY, next); } catch (e) {}
    });
  })();
</script>
