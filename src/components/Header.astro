---
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));
---
<header class="site-head">
  <div class="site-head-inner">
    <a class="brand" href="/" aria-label="home">
      <span class="blk" aria-hidden="true"></span>
      <span>Canberk Efe<span class="accent">.dev</span></span>
    </a>
    <nav class="nav-links" aria-label="primary">
      <a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>about</a>
      <a href="/blog"  aria-current={isActive('/blog')  ? 'page' : undefined}>blog</a>
      <a href="/tags"  aria-current={isActive('/tags')  ? 'page' : undefined}>tags</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
