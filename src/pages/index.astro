---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
---
<Base>
  <div class="center-stage">
    <Terminal>
      <div class="line"><span class="sigil">$</span><span class="cmd">whoami</span></div>
      <h1 class="hero">Canberk Efe<span class="cursor" aria-hidden="true"></span></h1>

      <div class="line gap"><span class="sigil">$</span><span class="cmd">cat ./about.txt</span></div>
      <div class="line"><span class="arrow">&gt;</span><span class="out">reverse engineering · firmware analysis · vuln research</span></div>
      <div class="line"><span class="arrow">&gt;</span><span class="out">i take things apart until they make sense.</span></div>

      <div class="line gap"><span class="sigil">$</span><span class="cmd">status</span></div>
      <div class="line"><span class="badge">IN PROGRESS</span></div>

      <div class="line gap"><span class="sigil">$</span><span class="cmd">ls ./elsewhere</span></div>
      <div class="links" role="list">
        <a href="https://github.com/crazyreverser" aria-label="GitHub" rel="me noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        </a>
        <a href="https://x.com/canberkefe_" aria-label="X / Twitter" rel="me noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/canberkefe/" aria-label="LinkedIn" rel="me noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        </a>
        <a href="mailto:contact@canberkefe.dev" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        </a>
      </div>

      <div class="line gap"><span class="sigil">$</span><span class="cmd">exit 0</span></div>
    </Terminal>
  </div>
</Base>
